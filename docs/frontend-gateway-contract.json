{
  "name": "smart-cone-frontend-gateway-contract",
  "title": "智能路锥上位机与前端对接数据（无 GPS/UWB 融合版）",
  "version": "1.1.0",
  "updatedAt": "2026-06-17",
  "currentMode": {
    "name": "gateway_direct_position",
    "description": "当前 GPS / UWB 硬件不可用，不做 UWB+GPS 融合。上位机直接输出最终 GCJ-02 经纬度，前端只消费 cone.telemetry.payload.position 作为地图主位置。",
    "mapPositionSource": "cone.telemetry.payload.position",
    "notUsedForMapPosition": [
      "gps.position",
      "uwb.position",
      "fused.position"
    ]
  },
  "projectScene": {
    "name": "重庆大学虎溪校区交叉创新中心",
    "coordinateSystem": "GCJ-02",
    "fallbackCenter": {
      "lng": 106.293186,
      "lat": 29.593694
    },
    "zoom": 18
  },
  "transport": {
    "websocket": {
      "defaultUrl": "ws://localhost:8080/ws",
      "direction": "bidirectional",
      "encoding": "utf-8",
      "messageFormat": "json",
      "frontendReceives": [
        "cone.telemetry",
        "imu.raw",
        "tilt.status",
        "gateway.status",
        "route.plan",
        "route.guide",
        "route.status",
        "command.ack"
      ],
      "frontendSends": [
        "cone.move.command"
      ],
      "note": "当前版本地图主位置只使用 cone.telemetry.payload.position；GPS/UWB 坏掉或不用时，不需要推 gps.position / uwb.position / fused.position。"
    },
    "tcpFromLowerComputer": {
      "defaultHost": "0.0.0.0",
      "defaultPort": 9000,
      "lineFormat": "JSON line, 每条消息以换行符结尾",
      "minimalInput": {
        "type": "telemetry",
        "coneId": "cone_01",
        "lng": 106.293186,
        "lat": 29.593694,
        "accuracy": 1.0
      },
      "note": "下位机或调试脚本只要能给出最终 lng/lat，上位机就会包装成 cone.telemetry 推给前端。type 写 telemetry / gps / uwb / position 时，当前上位机都会按最终坐标处理。"
    }
  },
  "devices": [
    {
      "coneId": "cone_01",
      "label": "C1",
      "defaultPosition": {
        "lng": 106.29302,
        "lat": 29.59386,
        "coordSys": "GCJ-02"
      }
    },
    {
      "coneId": "cone_02",
      "label": "C2",
      "defaultPosition": {
        "lng": 106.29336,
        "lat": 29.59353,
        "coordSys": "GCJ-02"
      }
    }
  ],
  "enums": {
    "positionSource": [
      "tcp_gateway",
      "http_gateway",
      "manual_gateway",
      "sim_initial",
      "frontend_drag_preview",
      "frontend_drag_target"
    ],
    "coneMode": [
      "STANDBY_DIM",
      "BLOCK_RED",
      "GUIDE_LEFT_ARROW",
      "GUIDE_RIGHT_ARROW",
      "WARN_CROWD_ORANGE",
      "ALARM_HELP_RED",
      "ALARM_FALLEN_RED",
      "OFFLINE"
    ],
    "ackStatus": [
      "accepted",
      "rejected",
      "executing",
      "done",
      "failed"
    ]
  },
  "schemas": {
    "position": {
      "lng": {
        "type": "number",
        "required": true,
        "description": "经度，GCJ-02"
      },
      "lat": {
        "type": "number",
        "required": true,
        "description": "纬度，GCJ-02"
      },
      "accuracyM": {
        "type": "number",
        "required": false,
        "description": "定位精度半径，单位 m"
      },
      "source": {
        "type": "string",
        "required": true,
        "description": "当前推荐 tcp_gateway，表示上位机直接给出的最终展示坐标"
      },
      "stale": {
        "type": "boolean",
        "required": false,
        "description": "该位置是否过期"
      }
    },
    "imu": {
      "rollDeg": {
        "type": "number",
        "required": true
      },
      "pitchDeg": {
        "type": "number",
        "required": true
      },
      "yawDeg": {
        "type": "number",
        "required": false
      },
      "calibrated": {
        "type": "boolean",
        "required": false
      }
    },
    "tilt": {
      "fallen": {
        "type": "boolean",
        "required": true
      },
      "angleDeg": {
        "type": "number",
        "required": false
      },
      "thresholdDeg": {
        "type": "number",
        "required": false
      },
      "calibration": {
        "type": "string",
        "required": false
      }
    }
  },
  "gatewayToFrontend": {
    "cone.telemetry": {
      "description": "上位机直接坐标遥测包；前端地图主位置只使用 payload.position。",
      "requiredPayloadFields": [
        "coneId",
        "position"
      ],
      "example": {
        "type": "cone.telemetry",
        "payload": {
          "coneId": "cone_01",
          "ts": 1781697600000,
          "online": true,
          "battery": 86,
          "mode": "STANDBY_DIM",
          "position": {
            "lng": 106.293186,
            "lat": 29.593694,
            "accuracyM": 1.0,
            "source": "tcp_gateway"
          },
          "imu": {
            "rollDeg": 1.2,
            "pitchDeg": -0.8,
            "yawDeg": 12,
            "calibrated": true
          },
          "tilt": {
            "fallen": false,
            "angleDeg": 1.2,
            "thresholdDeg": 55,
            "calibration": "zero_bias_ok"
          },
          "health": {
            "stale": false,
            "lastSeenMs": 1781697600000
          }
        }
      }
    },
    "imu.raw": {
      "description": "可选。只更新右侧 IMU 状态，不移动地图位置。",
      "example": {
        "type": "imu.raw",
        "payload": {
          "coneId": "cone_01",
          "rollDeg": 1.2,
          "pitchDeg": -0.8,
          "yawDeg": 12,
          "calibrated": true,
          "timestamp": 1781697600000
        }
      }
    },
    "tilt.status": {
      "description": "可选。只更新倾倒状态；fallen=true 时前端报警。",
      "example": {
        "type": "tilt.status",
        "payload": {
          "coneId": "cone_02",
          "fallen": true,
          "angleDeg": 76,
          "thresholdDeg": 55,
          "calibration": "zero_bias_ok",
          "timestamp": 1781697600000
        }
      }
    },
    "route.plan": {
      "description": "路径规划覆盖层。前端只绘制 polyline，不改变锥桶实际位置。",
      "example": {
        "type": "route.plan",
        "payload": {
          "coneId": "cone_01",
          "polyline": [
            {
              "lng": 106.293186,
              "lat": 29.593694
            },
            {
              "lng": 106.29326,
              "lat": 29.59372
            }
          ]
        }
      }
    },
    "gps.position": {
      "deprecated": true,
      "description": "当前不作为地图定位来源。GPS 坏掉或不用时不要推该事件；需要移动锥桶请推 cone.telemetry。"
    },
    "uwb.position": {
      "deprecated": true,
      "description": "当前不作为地图定位来源。UWB 坏掉或不用时不要推该事件；需要移动锥桶请推 cone.telemetry。"
    },
    "fused.position": {
      "deprecated": true,
      "description": "当前不做 UWB+GPS 融合，前端不依赖该事件。"
    }
  },
  "frontendToGateway": {
    "cone.move.command": {
      "description": "前端拖动锥桶后下发目标经纬度。上位机收到后可规划路径或直接控制设备。",
      "example": {
        "type": "cone.move.command",
        "requestId": "move_1781697600000_cone_01",
        "payload": {
          "coneId": "cone_01",
          "target": {
            "lng": 106.29326,
            "lat": 29.59372,
            "coordSys": "GCJ-02"
          },
          "source": "frontend_drag",
          "issuedAt": "2026-06-17T05:20:00.000Z",
          "ttlMs": 10000
        }
      },
      "note": "执行后上位机继续通过 cone.telemetry 上报最终位置，前端以上位机结果为准。"
    }
  },
  "minimalRecommendedTelemetry": {
    "type": "cone.telemetry",
    "payload": {
      "coneId": "cone_01",
      "ts": 1781697600000,
      "position": {
        "lng": 106.293186,
        "lat": 29.593694,
        "accuracyM": 1.0,
        "source": "tcp_gateway"
      },
      "health": {
        "stale": false,
        "lastSeenMs": 1781697600000
      }
    }
  }
}
